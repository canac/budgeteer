{
  "name": "budgeteer",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm db:generate && vite build",
    "build:analyze": "ANALYZE=true pnpm build",
    "start": "vite start",
    "prepare": "lefthook install",
    "console": "node --env-file=.env repl.ts",
    "db:format": "prisma format",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node --env-file=.env seed.ts",
    "fmt": "oxfmt --write .",
    "lint": "oxlint",
    "lint:ts": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/charts": "^9.3.0",
    "@mantine/core": "^9.3.0",
    "@mantine/form": "^9.3.0",
    "@mantine/hooks": "^9.3.0",
    "@mantine/notifications": "^9.3.0",
    "@prisma/client": "^7.8.0",
    "@std/cache": "jsr:^0.2.0",
    "@std/collections": "jsr:^1.1.3",
    "@tabler/icons-react": "^3.34.1",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.11",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.1.0",
    "prisma": "^7.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.0.0",
    "tiny-invariant": "^1.3.3",
    "undici": "^8.5.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@netlify/vite-plugin-tanstack-start": "^1.3.14",
    "@prisma/adapter-pg": "^7.8.0",
    "@types/node": "^22.17.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "lefthook": "^1.13.4",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "pg": "^8.20.0",
    "typescript": "7.0.1-rc",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@11.0.8"
}
