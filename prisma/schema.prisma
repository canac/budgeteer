// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/prisma"
  moduleFormat = "esm"
  engineType   = "client"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  TRANSACTION
  TRANSFER
  BALANCE_ADJUSTMENT
}

model Budget {
  id               String           @id @default(uuid(7))
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  month            String
  income           Int
  budgetCategories BudgetCategory[]
}

model Category {
  id                    String                @id @default(uuid(7))
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  name                  String
  accumulating          Boolean               @default(false)
  flexible              Boolean               @default(true)
  sortOrder             Float
  createdMonth          String
  deletedMonth          String?
  transactionCategories TransactionCategory[]
  budgetCategories      BudgetCategory[]
  transfersFrom         Transfer[]            @relation("TransferSource")
  transfersTo           Transfer[]            @relation("TransferDestination")
  categorizationRules   CategorizationRule[]
}

model BudgetCategory {
  id             String   @id @default(uuid(7))
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  budgetedAmount Int      @default(0)
  categoryId     String
  budgetId       String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  budget         Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([categoryId, budgetId])
}

model Transaction {
  id                    String                @id @default(uuid(7))
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  type                  TransactionType       @default(TRANSACTION)
  amount                Int
  date                  String
  vendor                String
  description           String?
  transactionCategories TransactionCategory[]
  transfer              Transfer?
  tellerId              String?               @unique
  tellerTransaction     TellerTransaction?    @relation(fields: [tellerId], references: [id], onDelete: SetNull)
}

model TransactionCategory {
  id            String      @id @default(uuid(7))
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  amount        Int
  transactionId String
  categoryId    String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([transactionId, categoryId])
}

model Transfer {
  id                    String      @id @default(uuid(7))
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  amount                Int
  sourceCategoryId      String
  destinationCategoryId String
  transactionId         String      @unique
  sourceCategory        Category    @relation("TransferSource", fields: [sourceCategoryId], references: [id], onDelete: Cascade)
  destinationCategory   Category    @relation("TransferDestination", fields: [destinationCategoryId], references: [id], onDelete: Cascade)
  transaction           Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model TellerEnrollment {
  id          String          @id // The teller ID
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  accessToken String
  accounts    TellerAccount[]
}

model TellerAccount {
  id           String              @id // The teller ID
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  name         String
  institution  String
  creditCard   Boolean             @default(false)
  enabled      Boolean             @default(true)
  lastSyncedAt DateTime?
  enrollmentId String
  enrollment   TellerEnrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  transactions TellerTransaction[]
}

model TellerTransaction {
  id          String        @id // The teller ID
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  amount      Int
  date        String
  vendor      String
  reviewed    Boolean       @default(false)
  accountId   String
  account     TellerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction Transaction?
}

model CategorizationRule {
  id           String    @id @default(uuid(7))
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tellerVendor String    @unique
  vendor       String
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
}
