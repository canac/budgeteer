{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "react", "vitest"],
  "options": {
    "typeAware": true
  },
  "rules": {
    "no-console": "error",
    "object-shorthand": "error"
  },
  "settings": {
    "vitest": {
      "typecheck": false
    }
  }
}
